{
  "version": 2,
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "create-react-app",
  "env": {
    "CI": "false",
    "DISABLE_ESLINT": "true",
    "SKIP_PREFLIGHT_CHECK": "true",
    "GENERATE_SOURCEMAP": "false"
  },
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://eccomerce-spring-2.onrender.com/api/auth/:path*"
    },
    {
      "source": "/api/products/:path*",
      "destination": "https://eccomerce-spring-2.onrender.com/api/products/:path*"
    },
    {
      "source": "/api/orders/:path*",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/orders/:path*"
    },
    {
      "source": "/api/cart/:path*",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/cart/:path*"
    },
    {
      "source": "/api/payment/:path*",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/payment/:path*"
    },
    {
      "source": "/api/notifications/:path*",
      "destination": "https://eccomerce-notification.onrender.com/api/notifications/:path*"
    },
    {
      "source": "/((?!api|static|favicon\\.ico|manifest\\.json|logo192\\.png|logo512\\.png|robots\\.txt|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
