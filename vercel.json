{
  "version": 2,
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "create-react-app",
  "env": {
    "CI": "false",
    "DISABLE_ESLINT": "true",
    "SKIP_PREFLIGHT_CHECK": "true",
    "GENERATE_SOURCEMAP": "false"
  },
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/products/(.*)",
      "destination": "https://eccomerce-spring-2.onrender.com/api/products/$1"
    },
    {
      "source": "/api/products",
      "destination": "https://eccomerce-spring-2.onrender.com/api/products"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "https://eccomerce-spring-2.onrender.com/api/auth/$1"
    },
    {
      "source": "/api/auth",
      "destination": "https://eccomerce-spring-2.onrender.com/api/auth"
    },
    {
      "source": "/api/orders/(.*)",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/orders/$1"
    },
    {
      "source": "/api/orders",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/orders"
    },
    {
      "source": "/api/cart/(.*)",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/cart/$1"
    },
    {
      "source": "/api/cart",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/cart"
    },
    {
      "source": "/api/payment/(.*)",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/payment/$1"
    },
    {
      "source": "/api/payment",
      "destination": "https://eccomerce-orderhandling.onrender.com/api/payment"
    },
    {
      "source": "/api/notifications/(.*)",
      "destination": "https://eccomerce-notification.onrender.com/api/notifications/$1"
    },
    {
      "source": "/api/notifications",
      "destination": "https://eccomerce-notification.onrender.com/api/notifications"
    },
    {
      "source": "/((?!api|static|favicon\\.ico|manifest\\.json|logo192\\.png|logo512\\.png|robots\\.txt|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}